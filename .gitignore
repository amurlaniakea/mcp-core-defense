# ============================================================
# .gitignore for mcp-core-defense
# Python / Node / LaTeX / IDE / OS
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
venv/
env/
.env
.venv
pip-log.txt
pip-delete-this-directory.txt
*.whl
*.spec
.mypy_cache/
.pytest_cache/
.pytype/
.ruff_cache/
coverage_html/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/
dmypy.json
pyrightconfig.json

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
package-lock.json
yarn.lock

# --- LaTeX / TeX ---
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.lof
*.lot
*.idx
*.ilg
*.ind
*.glo
*.gls
*.alg
*.acr
*.acn
*.glg
*.ist
*.run.xml
*.bcf
*.nav
*.snm
*.vrb
*.xdv
# Keep .tex, .bib, .sty, .cls, .pdf (final output)
# Uncomment next line to also ignore PDFs:
# *.pdf

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace
.history/
*.code-workspace

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Secrets / Credentials ---
*.pem
*.key
*.p12
*.pfx
*.env
.env.*
!.env.example
secrets/
credentials/
*credentials*
*secret*

# --- Binaries / Large Files ---
*.bin
*.exe
*.dll
*.dylib
*.so
*.o
*.a
*.lib
*.class
*.jar
*.war
*.zip
*.tar.gz
*.rar
*.7z

# --- Logs ---
logs/
*.log
log/

# --- Temporary / Cache ---
tmp/
temp/
.cache/
*.tmp
*.temp
*.bak
*.orig

# --- Docker ---
docker-compose.override.yml
.dockerignore

# --- Keep these ---
!.gitkeep
!tests/.gitkeep
